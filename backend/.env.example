# Backend Environment Variables — copy this to .env and fill in your values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/portfolio_db

# Resend API key (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address to receive contact form messages
EMAIL_RECEIVER=your@email.com

# Port (optional — Render auto-assigns PORT)
PORT=5000
